# ============================================================
# Philia Vault - Exemple de configuration (à copier en .env)
#   cp .env.example .env
# Ce fichier ne contient AUCUNE vraie valeur et peut être commité.
# ============================================================

# --- Google Gemini (Coach IA) ---
# Obtenir une clé : https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# --- Google Sign-In ---
# Console Google Cloud > APIs & Services > Identifiants
# https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=

# --- Sign in with Apple ---
# Identifiant de service Apple (Services ID), créé dans
# https://developer.apple.com/account/resources/identifiers/list/serviceId
# Si vide, l'app bascule en mode "mock" pour les tests locaux.
APPLE_CLIENT_ID=

# --- Email (réinitialisation de mot de passe) ---
# Si vide, les emails sont simplement journalisés (mode simulation).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# --- Stripe (paiements / abonnements) ---
# Dashboard Stripe > Développeurs > Clés API
# https://dashboard.stripe.com/apikeys
# Si vide, l'app bascule en mode "mock" pour les tests locaux.
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
# Dashboard Stripe > Développeurs > Webhooks (signing secret de l'endpoint)
# https://dashboard.stripe.com/webhooks
STRIPE_WEBHOOK_SECRET=

# --- RevenueCat (achats in-app mobile) ---
# Dashboard RevenueCat > Project Settings > API Keys
# https://app.revenuecat.com/
REVENUECAT_API_KEY=

# --- Base de données ---
# Chemin du fichier SQLite local
DATABASE_PATH=cashflow.db
# URL générique (réservée pour une future migration Postgres/MySQL)
DATABASE_URL=sqlite:///cashflow.db

# --- Flask ---
# Générer une valeur aléatoire forte, ex : python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=
# development | production
FLASK_ENV=development

# --- Chiffrement Fernet des données financières (montants, soldes, objectifs) ---
# Générer une clé Fernet : python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# ATTENTION : ne JAMAIS régénérer cette clé une fois des données chiffrées en
# base, sous peine de ne plus pouvoir les déchiffrer.
DB_ENCRYPTION_KEY=
ENCRYPTION_KEY=
