{
  "expo": {
    "name": "Philia Vault",
    "slug": "philia-vault",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "philiavault",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.philia.vault",
      "infoPlist": {
        "NSFaceIDUsageDescription": "Philia Vault utilise Face ID pour sécuriser l'accès à vos données financières."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundColor": "#000000"
      },
      "package": "com.philia.vault",
      "permissions": [
        "USE_BIOMETRIC",
        "USE_FINGERPRINT"
      ]
    },
    "plugins": [
      "expo-router",
      [
        "expo-font",
        {
          "fonts": []
        }
      ],
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Philia Vault utilise Face ID pour sécuriser l'accès à vos données financières."
        }
      ]
    ],
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/icon.png",
      "backgroundColor": "#000000",
      "themeColor": "#ccff00",
      "name": "Philia Vault",
      "shortName": "Philia Vault",
      "description": "Your financial mirror — AI-powered wealth management",
      "lang": "en",
      "scope": "/",
      "startUrl": "/",
      "display": "standalone",
      "orientation": "portrait",
      "preferRelatedApplications": false
    },
    "experiments": {
      "typedRoutes": true
    }
  }
}
