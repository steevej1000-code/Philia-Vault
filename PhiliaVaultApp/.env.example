# RevenueCat public client API keys (safe to ship in the app binary, but kept
# out of source control). Get these from the RevenueCat dashboard:
# Project Settings > API Keys > App-specific keys (Apple / Google Play).
#
# Copy this file to .env.local (already gitignored) and fill in real values.
EXPO_PUBLIC_REVENUECAT_IOS_API_KEY=
EXPO_PUBLIC_REVENUECAT_ANDROID_API_KEY=
